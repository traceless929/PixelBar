<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="PixelBar_App.Pages.LyricsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:PixelBar_App.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
        <Grid
            MaxWidth="{StaticResource AppContentMaxWidth}"
            Padding="{StaticResource AppPagePadding}"
            HorizontalAlignment="Center">
            <StackPanel Spacing="20">
                <controls:PageHeader
                    Subtitle="在 PixelBar 像素屏上同步显示 QQ 音乐歌词。使用前请关闭 TempoHub，并在设置中连接设备。"
                    Title="动态歌词 · QQ 音乐" />

                <InfoBar
                    x:Name="StatusBar"
                    IsOpen="False"
                    IsClosable="True" />

                <Border Style="{StaticResource SectionCardStyle}">
                    <StackPanel Spacing="16">
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <TextBlock Style="{StaticResource SectionLabelStyle}" Text="使用引导" />
                            <HyperlinkButton
                                Click="OpenWikiButton_Click"
                                Content="查看 Wiki 详细说明"
                                FontSize="12"
                                Padding="0"
                                VerticalAlignment="Center" />
                        </StackPanel>

                        <StackPanel Spacing="14">
                            <StackPanel Orientation="Horizontal" Spacing="12">
                                <Border
                                    Width="28"
                                    Height="28"
                                    Background="{ThemeResource AccentFillColorDefaultBrush}"
                                    CornerRadius="14">
                                    <TextBlock
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        FontSize="12"
                                        FontWeight="SemiBold"
                                        Foreground="White"
                                        Text="1" />
                                </Border>
                                <TextBlock
                                    VerticalAlignment="Center"
                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                    Text="关闭 EDIFIER TempoHub，USB 连接 PixelBar，在「设置」中选择设备。"
                                    TextWrapping="Wrap" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Spacing="12">
                                <Border
                                    Width="28"
                                    Height="28"
                                    Background="{ThemeResource AccentFillColorDefaultBrush}"
                                    CornerRadius="14">
                                    <TextBlock
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        FontSize="12"
                                        FontWeight="SemiBold"
                                        Foreground="White"
                                        Text="2" />
                                </Border>
                                <TextBlock
                                    VerticalAlignment="Center"
                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                    Text="用 QQ 音乐播放歌曲（需已缓存歌词，完整播放一遍通常即可）。"
                                    TextWrapping="Wrap" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Spacing="12">
                                <Border
                                    Width="28"
                                    Height="28"
                                    Background="{ThemeResource AccentFillColorDefaultBrush}"
                                    CornerRadius="14">
                                    <TextBlock
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        FontSize="12"
                                        FontWeight="SemiBold"
                                        Foreground="White"
                                        Text="3" />
                                </Border>
                                <TextBlock
                                    VerticalAlignment="Center"
                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                    Text="下方开启「启用歌词推送」；若先开 PixelBar 后开 QQ 音乐，一般会自动检测，也可点「重新同步」。"
                                    TextWrapping="Wrap" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Spacing="12">
                                <Border
                                    Width="28"
                                    Height="28"
                                    Background="{ThemeResource AccentFillColorSecondaryBrush}"
                                    CornerRadius="14">
                                    <TextBlock
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        FontSize="12"
                                        FontWeight="SemiBold"
                                        Foreground="White"
                                        Text="4" />
                                </Border>
                                <TextBlock
                                    VerticalAlignment="Center"
                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                    Text="若歌词与进度不同步，调整「时间偏移」；长句可开启滚动并选择方向。"
                                    TextWrapping="Wrap" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Spacing="12">
                                <Border
                                    Width="28"
                                    Height="28"
                                    Background="{ThemeResource AccentFillColorSecondaryBrush}"
                                    CornerRadius="14">
                                    <TextBlock
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        FontSize="12"
                                        FontWeight="SemiBold"
                                        Foreground="White"
                                        Text="5" />
                                </Border>
                                <TextBlock
                                    VerticalAlignment="Center"
                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                    Text="仍无歌词时，可开启 QQ 音乐「桌面歌词」作为回退，或检查下方诊断信息。"
                                    TextWrapping="Wrap" />
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource SectionCardStyle}">
                    <StackPanel Spacing="16">
                        <TextBlock Style="{StaticResource SectionLabelStyle}" Text="推送设置" />
                        <ToggleSwitch
                            x:Name="EnableSwitch"
                            Header="启用歌词推送"
                            OffContent="关闭"
                            OnContent="开启"
                            Toggled="EnableSwitch_Toggled" />
                        <TextBlock
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            FontSize="12"
                            Text="开启后后台约每秒检测 QQ 音乐；先开 PixelBar 再开 QQ 音乐也会自动接上，无需重启应用。"
                            TextWrapping="Wrap" />

                        <Button
                            x:Name="ResyncButton"
                            Click="ResyncButton_Click"
                            Content="重新同步"
                            HorizontalAlignment="Left"
                            IsEnabled="{Binding ElementName=EnableSwitch, Path=IsOn}" />

                        <ToggleSwitch
                            x:Name="ScrollSwitch"
                            Header="长句滚动显示"
                            IsEnabled="{Binding ElementName=EnableSwitch, Path=IsOn}"
                            OffContent="居中静态"
                            OnContent="超出长度时滚动"
                            Toggled="ScrollSwitch_Toggled" />

                        <StackPanel x:Name="ScrollDirectionPanel" Spacing="12" Visibility="Collapsed">
                            <TextBlock
                                FontSize="12"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                Text="滚动方向" />
                            <RadioButtons
                                x:Name="ScrollDirectionGroup"
                                IsEnabled="{Binding ElementName=EnableSwitch, Path=IsOn}"
                                MaxColumns="2"
                                SelectionChanged="ScrollDirectionGroup_SelectionChanged">
                                <RadioButton Content="左 → 右" IsChecked="True" Tag="ltr" />
                                <RadioButton Content="右 → 左" Tag="rtl" />
                            </RadioButtons>
                        </StackPanel>

                        <NumberBox
                            x:Name="TimingOffsetBox"
                            Header="歌词时间偏移（毫秒）"
                            IsEnabled="{Binding ElementName=EnableSwitch, Path=IsOn}"
                            LargeChange="500"
                            Maximum="30000"
                            Minimum="-30000"
                            SmallChange="50"
                            SpinButtonPlacementMode="Inline"
                            ValueChanged="TimingOffsetBox_ValueChanged" />
                        <TextBlock
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            FontSize="12"
                            Text="在歌词文件时间轴上微调：正数晚一些，负数早一些。建议从 ±200～500 试起。"
                            TextWrapping="Wrap" />
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource SectionCardStyle}">
                    <StackPanel Spacing="10">
                        <TextBlock Style="{StaticResource SectionLabelStyle}" Text="运行状态" />
                        <TextBlock
                            x:Name="StateText"
                            FontSize="16"
                            FontWeight="SemiBold"
                            Text="未启用"
                            TextWrapping="Wrap" />
                        <Border
                            Padding="12"
                            Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                            CornerRadius="8">
                            <StackPanel Spacing="6">
                                <TextBlock
                                    x:Name="SongText"
                                    FontWeight="SemiBold"
                                    Text="—"
                                    TextWrapping="Wrap" />
                                <TextBlock
                                    x:Name="LineText"
                                    FontSize="18"
                                    Text="—"
                                    TextWrapping="Wrap" />
                                <TextBlock
                                    x:Name="SourceText"
                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                    FontSize="12"
                                    Text="来源：—"
                                    TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>
                        <TextBlock
                            x:Name="DiagnosticText"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            FontSize="11"
                            Text="—"
                            TextWrapping="Wrap" />
                    </StackPanel>
                </Border>

                <Expander Header="高级选项" IsExpanded="False">
                    <StackPanel Spacing="12" Padding="0,8,0,0">
                        <TextBlock
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            Text="QQ 音乐会在 QQMusicLyricNew 写入加密 qrc；PixelBar 解密后缓存至 %LocalAppData%\PixelBar\LyricCache，便于二次利用。"
                            TextWrapping="Wrap" />
                        <TextBox
                            x:Name="LyricDirBox"
                            Header="QQ 音乐缓存根目录"
                            PlaceholderText="留空则读注册表 CACHEPATH"
                            TextChanged="LyricDirBox_TextChanged" />
                    </StackPanel>
                </Expander>
            </StackPanel>
        </Grid>
    </ScrollViewer>
</Page>
