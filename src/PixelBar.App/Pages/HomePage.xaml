<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="PixelBar_App.Pages.HomePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:PixelBar_App.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
        <Grid
            MaxWidth="{StaticResource AppContentMaxWidth}"
            Padding="{StaticResource AppPagePadding}"
            HorizontalAlignment="Center">
            <StackPanel Spacing="20">
                <controls:PageHeader
                    Subtitle="在像素屏上显示自定义文字。静态模式建议不超过 16 字；发送前会自动写入布局包。"
                    Title="文字显示" />

                <InfoBar
                    x:Name="StatusBar"
                    IsOpen="False"
                    IsClosable="True" />

                <Border Style="{StaticResource SectionCardStyle}">
                    <StackPanel Spacing="16">
                        <TextBox
                            x:Name="TextInput"
                            AcceptsReturn="False"
                            Header="屏幕文字"
                            MaxLength="16"
                            PlaceholderText="输入要显示的文字…"
                            Text="你好 PixelBar"
                            TextChanged="TextInput_TextChanged" />
                        <TextBlock
                            x:Name="CharCountText"
                            HorizontalAlignment="Right"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            FontSize="12"
                            Text="8 / 16" />
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource SectionCardStyle}">
                    <StackPanel Spacing="16">
                        <TextBlock Style="{StaticResource SectionLabelStyle}" Text="显示效果" />
                        <RadioButtons x:Name="EffectGroup" MaxColumns="2" SelectionChanged="EffectGroup_SelectionChanged">
                            <RadioButton Content="静态显示" IsChecked="True" Tag="static" />
                            <RadioButton Content="滚动字幕" Tag="scroll" />
                        </RadioButtons>

                        <StackPanel x:Name="AlignPanel" Spacing="12">
                            <TextBlock Style="{StaticResource SectionLabelStyle}" Text="对齐方式" />
                            <RadioButtons x:Name="AlignGroup" MaxColumns="2">
                                <RadioButton Content="左对齐" Tag="left" />
                                <RadioButton Content="居中" IsChecked="True" Tag="center" />
                                <RadioButton Content="右对齐" Tag="right" />
                                <RadioButton Content="两端对齐" Tag="justify" />
                            </RadioButtons>
                        </StackPanel>

                        <StackPanel x:Name="ScrollPanel" Spacing="12" Visibility="Collapsed">
                            <TextBlock Style="{StaticResource SectionLabelStyle}" Text="滚动方向" />
                            <RadioButtons x:Name="ScrollDirectionGroup" MaxColumns="2">
                                <RadioButton Content="左 → 右" IsChecked="True" Tag="ltr" />
                                <RadioButton Content="右 → 左" Tag="rtl" />
                            </RadioButtons>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <Button
                    x:Name="SendButton"
                    Click="SendButton_Click"
                    Content="发送到屏幕"
                    Style="{StaticResource PrimaryActionButtonStyle}" />
            </StackPanel>
        </Grid>
    </ScrollViewer>
</Page>
