<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="PixelBar_App.Pages.ScreenColorPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:PixelBar_App.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:PixelBar_App.Pages"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
        <Grid
            MaxWidth="{StaticResource AppContentMaxWidth}"
            Padding="{StaticResource AppPagePadding}"
            HorizontalAlignment="Center">
            <StackPanel Spacing="20">
                <controls:PageHeader
                    Subtitle="调整像素屏整体色调，与 TempoHub「像素屏颜色设置」协议一致。"
                    Title="像素屏 · 颜色" />

                <InfoBar
                    x:Name="StatusBar"
                    IsOpen="False"
                    IsClosable="True" />

                <Border Style="{StaticResource SectionCardStyle}">
                    <StackPanel Spacing="16">
                        <TextBlock Style="{StaticResource SectionLabelStyle}" Text="主题颜色" />
                        <ColorPicker
                            x:Name="ColorPicker"
                            ColorSpectrumShape="Ring"
                            IsColorChannelTextInputVisible="True"
                            IsColorPreviewVisible="True"
                            IsColorSliderVisible="True"
                            IsHexInputVisible="True"
                            IsMoreButtonVisible="False" />
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource SectionCardStyle}">
                    <StackPanel Spacing="12">
                        <TextBlock Style="{StaticResource SectionLabelStyle}" Text="快捷预设" />
                        <ItemsRepeater x:Name="PresetRepeater">
                            <ItemsRepeater.Layout>
                                <UniformGridLayout
                                    MinColumnSpacing="10"
                                    MinItemHeight="52"
                                    MinItemWidth="52"
                                    MinRowSpacing="10"
                                    MaximumRowsOrColumns="8" />
                            </ItemsRepeater.Layout>
                            <ItemsRepeater.ItemTemplate>
                                <DataTemplate x:DataType="local:ColorPresetItem">
                                    <Button
                                        Width="52"
                                        Height="52"
                                        Padding="0"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        Click="PresetButton_Click"
                                        Tag="{x:Bind Hex}"
                                        ToolTipService.ToolTip="{x:Bind Label}">
                                        <Border
                                            Width="40"
                                            Height="40"
                                            Background="{x:Bind Brush}"
                                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                            BorderThickness="2"
                                            CornerRadius="20" />
                                    </Button>
                                </DataTemplate>
                            </ItemsRepeater.ItemTemplate>
                        </ItemsRepeater>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource SectionCardStyle}">
                    <CheckBox
                        x:Name="SyncLightCheckBox"
                        Content="同时同步氛围灯颜色（实验性）" />
                </Border>

                <Button
                    x:Name="ApplyButton"
                    Click="ApplyButton_Click"
                    Content="应用颜色"
                    Style="{StaticResource PrimaryActionButtonStyle}" />
            </StackPanel>
        </Grid>
    </ScrollViewer>
</Page>
