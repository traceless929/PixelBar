<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="PixelBar_App.Pages.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:PixelBar_App.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:PixelBar_App.Pages"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
        <Grid
            MaxWidth="{StaticResource AppContentMaxWidth}"
            Padding="{StaticResource AppPagePadding}"
            HorizontalAlignment="Center">
            <StackPanel Spacing="20">
                <controls:PageHeader
                    Subtitle="设备连接、开机启动与托盘行为。"
                    Title="设置" />

                <InfoBar
                    x:Name="StatusBar"
                    IsOpen="False"
                    IsClosable="True" />

                <Border Style="{StaticResource SectionCardStyle}">
                    <StackPanel Spacing="12">
                        <TextBlock Style="{StaticResource SectionLabelStyle}" Text="应用行为" />
                        <ToggleSwitch
                            x:Name="RunAtStartupSwitch"
                            OffContent="关闭"
                            OnContent="开启"
                            Toggled="RunAtStartupSwitch_Toggled">
                            <ToggleSwitch.Header>
                                <StackPanel Spacing="2">
                                    <TextBlock Text="开机自动启动" />
                                    <TextBlock
                                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                        Text="登录 Windows 后自动运行 PixelBar"
                                        TextWrapping="Wrap" />
                                </StackPanel>
                            </ToggleSwitch.Header>
                        </ToggleSwitch>
                        <ToggleSwitch
                            x:Name="MinimizeToTraySwitch"
                            OffContent="关闭"
                            OnContent="开启"
                            Toggled="MinimizeToTraySwitch_Toggled">
                            <ToggleSwitch.Header>
                                <StackPanel Spacing="2">
                                    <TextBlock Text="关闭时最小化到通知区域" />
                                    <TextBlock
                                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                        Text="点击窗口关闭按钮时隐藏到托盘；在托盘图标上选择「退出」才会完全关闭"
                                        TextWrapping="Wrap" />
                                </StackPanel>
                            </ToggleSwitch.Header>
                        </ToggleSwitch>
                        <Button
                            HorizontalAlignment="Left"
                            Click="ShowWelcomeButton_Click"
                            Content="查看使用引导" />
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource SectionCardStyle}">
                    <StackPanel Spacing="12">
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <TextBlock
                                VerticalAlignment="Center"
                                Style="{StaticResource SectionLabelStyle}"
                                Text="当前设备" />
                            <Button
                                x:Name="RefreshButton"
                                Click="RefreshButton_Click"
                                Content="刷新" />
                        </StackPanel>
                        <TextBlock
                            x:Name="CurrentDeviceName"
                            FontSize="16"
                            FontWeight="SemiBold"
                            Text="—" />
                        <TextBlock
                            x:Name="CurrentDevicePath"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            FontFamily="Consolas"
                            FontSize="12"
                            Text="—"
                            TextWrapping="Wrap" />
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource SectionCardStyle}">
                    <StackPanel Spacing="12">
                        <TextBlock Style="{StaticResource SectionLabelStyle}" Text="可用设备" />
                        <ListView
                            x:Name="DeviceList"
                            IsItemClickEnabled="True"
                            ItemClick="DeviceList_ItemClick"
                            SelectionMode="Single">
                            <ListView.ItemTemplate>
                                <DataTemplate x:DataType="local:DeviceItem">
                                    <Grid Padding="4,6" ColumnSpacing="12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <FontIcon
                                            Grid.Column="0"
                                            VerticalAlignment="Center"
                                            Foreground="{ThemeResource AccentFillColorDefaultBrush}"
                                            Glyph="&#xECAA;" />
                                        <StackPanel Grid.Column="1" Spacing="4">
                                            <TextBlock FontWeight="SemiBold" Text="{x:Bind DisplayName}" />
                                            <TextBlock
                                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                FontFamily="Consolas"
                                                FontSize="11"
                                                Text="{x:Bind DevicePath}"
                                                TextWrapping="Wrap" />
                                        </StackPanel>
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource SectionCardStyle}">
                    <StackPanel Spacing="8">
                        <TextBlock Style="{StaticResource SectionLabelStyle}" Text="关于 PixelBar" />
                        <TextBlock
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            Text="开源 Halo PixelBar 控制客户端 · 文字 · 灯光 · 时钟 · 频谱 · 屏色"
                            TextWrapping="Wrap" />
                        <TextBlock
                            x:Name="VersionText"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            Text="版本 —" />
                        <TextBlock
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            Text="VID/PID 0x2D99 / 0xA106 · UsagePage 0xFF24"
                            TextWrapping="Wrap" />
                    </StackPanel>
                </Border>
            </StackPanel>
        </Grid>
    </ScrollViewer>
</Page>
